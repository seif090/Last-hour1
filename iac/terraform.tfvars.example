# ─── Last Hour Terraform Variables ─────────────────────────────────
# Copy this to terraform.tfvars and fill in your values

aws_region          = "me-south-1"
environment         = "production"
vpc_cidr            = "10.0.0.0/16"
availability_zones  = ["me-south-1a", "me-south-1b", "me-south-1c"]
domain_name         = "lasthour.app"
route53_zone_id     = "ZXXXXXXXXXXXXX"
acm_certificate_arn = "arn:aws:acm:me-south-1:XXXXXXXXXXXX:certificate/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

rds_instance_class     = "db.r6g.large"
rds_allocated_storage  = 100
rds_backup_retention   = 30
redis_node_type        = "cache.r6g.large"

backend_cpu            = "1024"
backend_memory         = "2048"
backend_desired_count  = 2
backend_image_url      = "XXXXXXXXXXXX.dkr.ecr.me-south-1.amazonaws.com/lasthour-backend:latest"

github_repository      = "seif090/Last-hour1"
datadog_site           = "datadoghq.eu"
