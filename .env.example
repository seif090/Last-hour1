# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://lasthour:lasthour_dev@localhost:5432/lasthour
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=25

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=lasthour:
REDIS_STOCK_TTL=30
REDIS_OFFER_TTL=60

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-256-bit-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=lasthour.app

# ─── Encryption ───────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=egp

# ─── Paymob ──────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=

# ─── Firebase Cloud Messaging ─────────────────────────────
FIREBASE_SERVICE_ACCOUNT_B64=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── Datadog APM ──────────────────────────────────────────
DD_TRACE_ENABLED=false
DD_SERVICE=lasthour-backend
DD_ENV=development
DD_LOGS_INJECTION=true
DD_API_KEY=
DD_SITE=datadoghq.eu

# ─── Google Maps ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── WebSocket ────────────────────────────────────────────
WS_PATH=/ws
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=10000

# ─── Rate Limiting ────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── File Uploads ─────────────────────────────────────────
AWS_S3_BUCKET=lasthour-uploads
AWS_S3_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_FILE_SIZE=5242880

# ─── Background Jobs ──────────────────────────────────────
BULL_QUEUE_PREFIX=lasthour:queue
OFFER_EXPIRY_CHECK_CRON=*/1 * * * *
